# ============================================================
# 後端環境變數範本 — 複製為 server/.env 後填入真值
# 紅線：真 token 只放 server/.env（已被 .gitignore 擋），永不進 git
# ============================================================

# Telegram Bot Token（向 @BotFather 申請）。缺這個後端會直接 fail loudly 不啟動。
TELEGRAM_BOT_TOKEN=

# 允許接收的群組 chat id（選填）。
# 留空＝V0 階段先不限制來源；正式上線建議綁定單一工作群組，避免別處訊息混入。
TELEGRAM_ALLOWED_CHAT_ID=

# long polling 等待秒數（Telegram getUpdates 的 timeout），預設 30。
TELEGRAM_POLL_TIMEOUT=30

# ---- 存活通知（選填）----
# bot 啟動/停止/崩潰時,主動把狀態訊息發到這個 chat id（建議用「管理對象」,
# 例如你與 bot 的私聊或一個運維群,避免在工作群洗版）。留空＝不發狀態通知。
TELEGRAM_ADMIN_CHAT_ID=

# ---- 外部心跳 / 死手開關（選填，抓「整台機器斷電/當死」用）----
# healthchecks.io 之類的 ping 網址。bot 會定時 ping,一旦機器沒了心跳就停,
# 由外部服務發警報。留空＝不發心跳。
HEALTHCHECK_URL=
# 心跳間隔（秒），預設 60，最小 10。
HEALTHCHECK_INTERVAL_SEC=60
