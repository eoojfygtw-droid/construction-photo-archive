# ============================================================
# 後端環境變數範本 — 複製為 server/.env 後填入真值
# 紅線：真 token 只放 server/.env（已被 .gitignore 擋），永不進 git
# ============================================================

# Telegram Bot Token（向 @BotFather 申請）。缺這個後端會直接 fail loudly 不啟動。
TELEGRAM_BOT_TOKEN=

# 允許接收的群組 chat id（選填）。
# 留空＝V0 階段先不限制來源；正式上線建議綁定單一工作群組，避免別處訊息混入。
TELEGRAM_ALLOWED_CHAT_ID=

# long polling 等待秒數（Telegram getUpdates 的 timeout），預設 30。
TELEGRAM_POLL_TIMEOUT=30
